# LLM Configuration
LLM_MODEL=glm-4-flash
LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Database Configuration
# 目前开发环境默认使用 SQLite
DB_TYPE=sqlite
DB_NAME=exam_helper.db
# 或者直接提供完整的数据库连接 URL
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Security
SECRET_KEY=replace_with_a_long_random_secret

# Runtime
APP_ENV=development

# CORS (comma-separated)
# 开发环境默认允许 http://localhost:3000 与 http://127.0.0.1:3000
# 生产环境建议显式配置，例如：
# CORS_ALLOW_ORIGINS=https://your-frontend.com,https://admin.your-frontend.com
CORS_ALLOW_ORIGINS=

# Bootstrap admin (optional, used by scripts/create_superuser.py)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_USERNAME=admin
ADMIN_ROLE=admin
